# Use Node.js 24 Alpine image
FROM node:24-alpine

# Create working directory
WORKDIR /app

# Copy dependency files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy Prisma schema
COPY prisma ./prisma

# Generate Prisma client
RUN npx prisma generate

# Copy the rest of the backend code
COPY . .

# Expose backend port
EXPOSE 4000

# Start backend server
CMD ["npm", "run", "dev"]